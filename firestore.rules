// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the admin email may write — authenticated via Firebase Auth
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ajayeswaran23@gmail.com';
    }

    // Sessions — public read, admin write
    match /sessions/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blogs — public read (published only enforced client-side + query),
    //         admin full access
    match /blogs/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Certifications — public read, admin write
    match /certifications/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages — anyone can submit (create), only admin can read/manage
    match /messages/{doc} {
      allow create: if
        // Must only have these fields — no injection of extra fields
        request.resource.data.keys().hasOnly(['name', 'email', 'subject', 'message', 'createdAt'])
        // Reasonable size limits to prevent abuse
        && request.resource.data.name.size()    > 0
        && request.resource.data.name.size()    < 200
        && request.resource.data.email.size()   > 0
        && request.resource.data.email.size()   < 200
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 2000;

      allow read, update, delete: if isAdmin();
    }
  }
}
