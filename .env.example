# ── Firebase ────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# ── Cloudinary ──────────────────────────────────────────────────────────────
# Your Cloudinary cloud name (e.g. "dxxxxxxxxx")
# VITE_ prefix makes it available in the browser bundle — this is intentional
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ── Sentry (optional — remove if not using) ────────────────────────────────
# Get DSN from Sentry → Settings → Projects → your-project → Client Keys
VITE_SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxxx
